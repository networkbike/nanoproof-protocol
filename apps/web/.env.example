# =============================================================================
# NanoProof Web — environment variables
# Copy to `.env.local` for local development; set in Vercel dashboard for prod.
# =============================================================================

# --- API endpoint -----------------------------------------------------------
# Local dev:   http://localhost:4000
# Production:  https://api.nanoproof.xyz  (Railway)
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Demo mode UI badge -----------------------------------------------------
# When set to "true", the dashboard renders the "Load demo dataset" card
# prominently. Set to "false" or leave unset for clean prod dashboards.
NEXT_PUBLIC_DEMO_MODE=true

# --- Optional: Clerk (Phase 7) ----------------------------------------------
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# --- Optional: Analytics ---------------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Vercel-only build knobs -----------------------------------------------
# Disable the Next.js telemetry beacon in production builds.
NEXT_TELEMETRY_DISABLED=1