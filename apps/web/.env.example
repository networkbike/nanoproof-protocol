# NanoProof Web — environment variables
# Copy this file to `.env.local` for local development.

# --- App -------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- API -------------------------------------------------------------------
NEXT_PUBLIC_NANOPROOF_API_URL=http://localhost:4000

# --- Clerk (auth) ----------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- Arc + WalletConnect ---------------------------------------------------
NEXT_PUBLIC_ARC_RPC_URL=https://testnet-rpc.arc.io
NEXT_PUBLIC_ARC_CHAIN_ID=arc-testnet
NEXT_PUBLIC_ARCSCAN_URL=https://testnet.arcscan.app
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Analytics -------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Observability ---------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=