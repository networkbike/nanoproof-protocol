# =============================================================================
# NanoProof API — environment variables
#
# Copy to `.env` (gitignored) for local development.
# Set in the Railway dashboard for production.
# =============================================================================

# --- Runtime -----------------------------------------------------------------
NODE_ENV=development                # production in Railway
PORT=4000                            # $PORT in Railway (injected by platform)
LOG_LEVEL=info                       # debug | info | warn | error
CORS_ORIGINS=http://localhost:3000   # comma-separated; in prod: https://nanoproof.xyz,https://www.nanoproof.xyz

# --- Database (Neon in prod, local Postgres in dev) --------------------------
# Local:   postgresql://postgres:postgres@localhost:5432/nanoproof
# Neon:    postgresql://USER:PASS@ep-xxx.region.aws.neon.tech/nanoproof?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nanoproof
DATABASE_SHADOW_URL=postgresql://postgres:postgres@localhost:5432/nanoproof_shadow

# --- Connection pool (Neon / PgBouncer) -------------------------------------
# Pool size for the Nest PrismaService; small because Neon bills by compute.
DATABASE_POOL_SIZE=10
DATABASE_POOL_TIMEOUT_MS=5000

# --- Arc L1 (testnet) --------------------------------------------------------
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_CHAIN_ID=arc-testnet
ARCSCAN_URL=https://testnet.arcscan.app

# --- USDC contract (testnet placeholder — replace before mainnet) ----------
USDC_ARC_TESTNET=0x3600000000000000000000000000000000000000
USDC_ARC_MAINNET=0x0000000000000000000000000000000000000000

# --- Agent hot wallet (DEV ONLY — Phase 9 migrates to KMS) ------------------
AGENT_WALLET_PRIVATE_KEY=
AGENT_WALLET_ADDRESS=

# --- Redis (BullMQ + rate limiting) -----------------------------------------
REDIS_URL=redis://localhost:6379

# --- Auth (Clerk) — optional in MVP, required in Phase 2 -------------------
CLERK_SECRET_KEY=
CLERK_JWT_KEY=
CLERK_WEBHOOK_SECRET=

# --- Rate limiting ------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=600
RATE_LIMIT_BURST=100

# --- Observability (optional in MVP) ----------------------------------------
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=nanoproof-api

# --- Feature flags -----------------------------------------------------------
PAYMENTS_ENABLED=true
CITATION_ENGINE_ENABLED=true

# --- Phase 7: Demo Mode ------------------------------------------------------
# When true, the POST /v1/analytics/demo/seed endpoint accepts calls.
# Required for the Lepton demo so judges can populate the dashboard with
# the canonical 100/500/1000/1000 dataset in one click.
# Set to "true" only on the prod api (the cookie-mounted web dashboard
# exposes the button only when NEXT_PUBLIC_DEMO_MODE=true is also set
# on the web side).
NANOPROOF_DEMO_MODE=false

# --- Phase 7: Health checks --------------------------------------------------
# /health, /liveness, /readiness are always mounted. No env var needed.
# Railway's healthcheckPath is /health (see apps/api/railway.toml).