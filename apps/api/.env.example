# NanoProof API — environment variables
# Copy this file to `.env` and fill in real values for local development.

# --- Server -----------------------------------------------------------------
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# --- Database (Neon in prod, local Postgres in dev) ------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nanoproof

# --- Auth (Clerk) -----------------------------------------------------------
CLERK_SECRET_KEY=
CLERK_JWT_KEY=
CLERK_WEBHOOK_SECRET=

# --- Circle (payments + gateway) -------------------------------------------
CIRCLE_API_KEY=
CIRCLE_GATEWAY_URL=https://gateway.circle.com
CIRCLE_WEBHOOK_SECRET=

# --- Arc L1 (settlement chain) ---------------------------------------------
ARC_RPC_URL=https://testnet-rpc.arc.io
ARC_CHAIN_ID=arc-testnet
ARCSCAN_URL=https://testnet.arcscan.app

# --- Agent hot wallet (signs payouts) --------------------------------------
# !! In production, source from KMS / MPC, not a raw env var !!
AGENT_WALLET_PRIVATE_KEY=
AGENT_WALLET_ADDRESS=

# --- USDC contract addresses (per network) ---------------------------------
USDC_ARC_TESTNET=0x0000000000000000000000000000000000000000
USDC_ARC_MAINNET=0x0000000000000000000000000000000000000000

# --- Worker queue (BullMQ + Redis) -----------------------------------------
REDIS_URL=redis://localhost:6379

# --- Observability ----------------------------------------------------------
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=nanoproof-api

# --- Feature flags ----------------------------------------------------------
PAYMENTS_ENABLED=true
CITATION_ENGINE_ENABLED=true
RATE_LIMIT_PER_MINUTE=600