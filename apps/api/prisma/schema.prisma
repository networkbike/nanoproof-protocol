// =============================================================================
// NanoProof Protocol — Prisma Schema V1 (MVP)
//
// Entities (per the MVP scope):
//   Creator    — registered human identity
//   Wallet     — chain address owned by a Creator (Arc testnet + future)
//   Source     — a piece of content registered by a Creator
//   Citation   — a simulated citation event (full pipeline in Phase 3)
//   Payment    — a simulated USDC payout (full pipeline in Phase 4)
//
// Architecture-level additions (Vault, Organization, ApiKey, Fingerprint,
// CitationKind enum, etc.) land in subsequent migrations per the
// .github/issues/phase-{2,3,4}/ tickets.
// =============================================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums
// -----------------------------------------------------------------------------

enum WalletNetwork {
  ARC_TESTNET
  ARC_MAINNET
  BASE
  BASE_SEPOLIA
  ETHEREUM
  ETHEREUM_SEPOLIA
  POLYGON
  POLYGON_AMOY
}

enum SourceStatus {
  DRAFT
  PENDING_VERIFICATION
  ACTIVE
  PAUSED
  REJECTED
  ARCHIVED
}

enum CitationKind {
  DIRECT
  INDIRECT
  SUPPORTING
  REFERENCE
  CONTEXT
}

enum PaymentStatus {
  PENDING
  QUOTED
  SETTLED
  CAPPED
  FAILED
}

// -----------------------------------------------------------------------------
// Creator
// -----------------------------------------------------------------------------

model Creator {
  id              String   @id @default(cuid()) // "cr_<ulid>"
  name            String
  username        String   @unique
  email           String   @unique
  bio             String?
  avatarUrl       String?
  reputationScore Int      @default(0)
  isActive        Boolean  @default(true)

  twitterHandle   String?
  githubHandle    String?
  websiteUrl      String?
  settings        Json     @default("{}")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  wallets   Wallet[]
  sources   Source[]
  citations Citation[]   @relation("CreatorCitations")
  payments  Payment[]    @relation("CreatorPayments")

  @@index([username])
  @@index([email])
  @@index([reputationScore])
  @@map("creators")
}

// -----------------------------------------------------------------------------
// Wallet
// -----------------------------------------------------------------------------

model Wallet {
  id           String          @id @default(cuid()) // "wl_<ulid>"
  creatorId    String
  address      String
  network      WalletNetwork
  label        String?
  isPrimary    Boolean         @default(false)

  // Verification (EIP-191 verification lives in Phase 2 P2-009)
  verificationStatus String     @default("UNVERIFIED")
  verifiedAt         DateTime?

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  creator      Creator         @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([address, network])
  @@index([creatorId])
  @@map("wallets")
}

// -----------------------------------------------------------------------------
// Source
// -----------------------------------------------------------------------------

model Source {
  id            String           @id @default(cuid()) // "src_<ulid>"
  creatorId     String
  title         String
  url           String
  domain        String
  description   String?

  // Pricing (atomic USDC; default $0.001 per citation)
  citationPrice String           @default("1000")
  minPayout     String           @default("100")
  periodCap     String?
  license       String           @default("all-rights-reserved")

  // Verification (real DNS/HTML/file in Phase 2 P2-012)
  status        SourceStatus     @default(ACTIVE)
  verifiedAt    DateTime?

  // Aggregates (denormalized, refreshed by a worker in Phase 6+)
  citationCount Int              @default(0)
  earnedAtomic  String           @default("0")

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  archivedAt    DateTime?

  creator       Creator          @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  citations     Citation[]
  payments      Payment[]

  @@unique([creatorId, url])
  @@index([creatorId, status])
  @@index([domain])
  @@map("sources")
}

// -----------------------------------------------------------------------------
// Citation (MVP-simulated; full engine in Phase 3)
// -----------------------------------------------------------------------------

model Citation {
  id                    String       @id @default(cuid()) // "cit_<ulid>"
  sourceId              String
  responseId            String?      // agent-supplied UUID; not enforced unique in MVP
  snippet               String

  // Detection result
  kind                  CitationKind  @default(DIRECT)

  // Scoring (full AttributionScorer replaces these in Phase 3)
  matchScore            String        @default("1.0000")
  confidence            String        @default("1.00")
  contributionFraction  String        @default("1.0000")
  payoutAmountUsdc      String        @default("1000") // atomic USDC

  // Status (PENDING until Payment Engine settles; MVP sets SETTLED on Payment.simulate)
  status                String        @default("PENDING")
  recordedAt            DateTime      @default(now())

  source                Source        @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  creators              Creator[]     @relation("CreatorCitations") // optional denormalized lookup

  @@index([sourceId])
  @@index([recordedAt])
  @@map("citations")
}

// -----------------------------------------------------------------------------
// Payment (MVP-simulated; full Payment Engine in Phase 4)
// -----------------------------------------------------------------------------

model Payment {
  id          String        @id @default(cuid()) // "pay_<ulid>"
  creatorId   String
  sourceId    String?
  amountUsdc  String        // atomic USDC
  currency    String        @default("USDC")
  network     String        @default("ARC_TESTNET")
  status      PaymentStatus @default(SETTLED)

  // Onchain (populated in Phase 4)
  txHash      String?
  arcScanUrl  String?
  blockNumber BigInt?
  settledAt   DateTime?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  creator     Creator       @relation("CreatorPayments", fields: [creatorId], references: [id], onDelete: Cascade)
  source      Source?       @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([creatorId, settledAt])
  @@index([status])
  @@map("payments")
}