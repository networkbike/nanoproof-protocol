// =============================================================================
// NanoProof Protocol — Prisma Schema (Phase 2: Creator Registry)
// =============================================================================
// This schema captures the canonical data model for the Creator Registry:
//   • Creator      — a person who registers content to receive citations
//   • Wallet       — a chain address owned by a Creator (Arc + future chains)
//   • Source       — a single piece of content registered by a Creator
//   • Organization — an optional group a Creator belongs to (team, studio, lab)
//   • ApiKey       — a long-lived credential issued to an Agent or a Creator's
//                    own integration
//
// Conventions
//   • All ids are CUIDs prefixed by entity: `cr_`, `wl_`, `src_`, `org_`, `ak_`.
//     The prefix is generated at the application layer; Prisma stores plain strings.
//   • Money is stored as strings of atomic units (USDC = 6 decimals). Never Float.
//   • Timestamps are UTC and always include a timezone-aware createdAt/updatedAt.
//   • Soft delete is used on Creator + Source; hard delete only on ApiKey revocation.
//
// Reference: docs/creator-registry.md, docs/wallet-verification.md,
//            docs/source-verification.md, docs/protocol-spec.md
// =============================================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums (centralized)
// -----------------------------------------------------------------------------

enum WalletNetwork {
  ARC_TESTNET
  ARC_MAINNET
  BASE
  BASE_SEPOLIA
  ETHEREUM
  ETHEREUM_SEPOLIA
  POLYGON
  POLYGON_AMOY
  // Future chain-portable additions land here per ADR-0001.
}

enum WalletVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REVOKED
}

enum SourceStatus {
  DRAFT                  // creator still editing
  PENDING_VERIFICATION   // verification challenge issued
  ACTIVE                 // payable by agents
  PAUSED                 // temporarily not payable (creator disabled)
  REJECTED               // verification failed permanently
  ARCHIVED               // soft-deleted
}

enum VerificationMethod {
  DNS_TXT
  HTML_META
  FILE_UPLOAD
  // Future: GITHUB_COMMIT, ARWEAVE_TX
}

enum ApiKeyScope {
  READ_ONLY
  CITATION_WRITE
  PAYMENT_WRITE
  ADMIN
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

// -----------------------------------------------------------------------------
// Organization (optional parent for Creators)
// -----------------------------------------------------------------------------

model Organization {
  id          String   @id @default(cuid()) // prefixed "org_"
  name        String
  slug        String   @unique
  description String?
  website     String?
  logoUrl     String?

  // Configuration
  settings    Json     @default("{}") // per-org overrides (routing, payouts)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  memberships OrganizationMembership[]
  sources     Source[]

  @@index([slug])
  @@map("organizations")
}

// Join table: which Creators belong to which Organizations and at what role.
model OrganizationMembership {
  id             String           @id @default(cuid())
  organizationId String
  creatorId      String
  role           OrganizationRole @default(MEMBER)
  invitedAt      DateTime         @default(now())
  acceptedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator      Creator      @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([organizationId, creatorId])
  @@index([creatorId])
  @@map("organization_memberships")
}

// -----------------------------------------------------------------------------
// Creator
// -----------------------------------------------------------------------------

model Creator {
  id              String   @id @default(cuid()) // prefixed "cr_"
  name            String
  username        String   @unique
  email           String   @unique
  bio             String?  @db.Text
  avatarUrl       String?
  reputationScore Int      @default(0) // computed; never set by clients directly
  isActive        Boolean  @default(true)

  // Stripe-like display metadata
  twitterHandle   String?
  githubHandle    String?
  websiteUrl      String?

  // Settings
  settings        Json     @default("{}") // notification prefs, default pricing tier

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime? // soft delete

  // Relations
  wallets       Wallet[]
  sources       Source[]
  apiKeys       ApiKey[]
  memberships   OrganizationMembership[]

  @@index([username])
  @@index([email])
  @@index([reputationScore])
  @@map("creators")
}

// -----------------------------------------------------------------------------
// Wallet
// -----------------------------------------------------------------------------

model Wallet {
  id                    String                  @id @default(cuid()) // prefixed "wl_"
  creatorId             String
  address               String // checksummed 0x... (lowercased for uniqueness)
  network               WalletNetwork
  label                 String? // "Primary", "Tips", "Co-author split", etc.
  isPrimary             Boolean                 @default(false)

  verificationStatus    WalletVerificationStatus @default(UNVERIFIED)
  verifiedAt            DateTime?
  verificationSignature String? // EIP-191 signature payload hex
  verificationMessage   String? // exact message that was signed
  verificationNonce     String? // one-time nonce consumed during verify

  // Indexer bookkeeping
  firstSeenBlock        BigInt?
  lastSeenBlock         BigInt?

  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt

  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@unique([address, network])
  @@index([creatorId])
  @@index([verificationStatus])
  @@map("wallets")
}

// -----------------------------------------------------------------------------
// Source — a single piece of content a creator registers to monetize
// -----------------------------------------------------------------------------

model Source {
  id                  String              @id @default(cuid()) // prefixed "src_"
  creatorId           String
  organizationId      String?

  title               String
  url                 String
  domain              String // derived from url, used for verification lookup
  description         String?             @db.Text

  // Pricing — string of atomic units, USDC = 6 decimals. E.g. "1000" = $0.001.
  citationPrice       String              @default("1000")
  minPayout           String              @default("100")
  periodCap           String?

  // License + content metadata
  license             String              @default("all-rights-reserved")
  contentHash         String? // sha256 of canonical content; populated post-fetch
  contentType         String? // mime type
  language            String?

  // Verification
  status              SourceStatus        @default(DRAFT)
  verificationMethod  VerificationMethod?
  verificationToken   String? // one-time challenge string (DNS / meta / file)
  verificationMeta    Json? // structured details: DNS record, meta tag location, etc.
  verifiedAt          DateTime?
  rejectionReason     String?

  // Cached embedding for Citation Engine (Phase 3+)
  embedding           Unsupported("vector(1536)")?
  embeddingModel      String?
  embeddedAt          DateTime?

  // Citation accounting (denormalized counters, refreshed by a worker)
  citationCount       Int                 @default(0)
  earnedAtomic        String              @default("0") // sum of settled payouts

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  archivedAt          DateTime? // soft delete

  creator      Creator       @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@unique([creatorId, url])
  @@index([creatorId, status])
  @@index([domain])
  @@index([status, verifiedAt])
  @@map("sources")
}

// -----------------------------------------------------------------------------
// ApiKey — credential for agent developers OR creator-owned integrations
// -----------------------------------------------------------------------------

model ApiKey {
  id            String      @id @default(cuid()) // prefixed "ak_"
  creatorId     String // owner of this key
  name          String // human label: "Production Agent", "Local Dev"
  prefix        String      @unique // first 8 chars of the plaintext key; for UI lookup
  keyHash       String // sha256 of the FULL plaintext key (returned once at creation)
  scope         ApiKeyScope @default(CITATION_WRITE)

  // Optional scoping
  allowedDomains String[]   @default([]) // empty = no restriction
  rateLimit      Int         @default(600) // requests per minute

  active        Boolean     @default(true)
  expiresAt     DateTime?
  lastUsedAt    DateTime?
  lastUsedIp    String?

  // Revocation audit
  revokedAt     DateTime?
  revokedReason String?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId, active])
  @@index([prefix])
  @@map("api_keys")
}

// -----------------------------------------------------------------------------
// VerificationChallenge — short-lived, single-use challenges for both wallet and
// source verification. Lets us audit every verify attempt.
// -----------------------------------------------------------------------------

model VerificationChallenge {
  id         String   @id @default(cuid())
  kind       String // "wallet" | "source"
  subjectId  String // walletId or sourceId
  token      String   @unique
  meta       Json? // { domain, message, expectedRecord, ... }
  expiresAt  DateTime
  consumedAt DateTime?
  ipAddress  String?
  userAgent  String?

  createdAt  DateTime @default(now())

  @@index([kind, subjectId])
  @@index([expiresAt])
  @@map("verification_challenges")
}